#!/bin/bash
set -euo pipefail

# --- Colors ---
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

green()  { printf "${GREEN}%s${RESET}\n" "$1"; }
yellow() { printf "${YELLOW}%s${RESET}\n" "$1"; }
red()    { printf "${RED}%s${RESET}\n" "$1"; }
bold()   { printf "${BOLD}%s${RESET}\n" "$1"; }

ORCHESTRA_DIR="$(cd "$(dirname "$0")" && pwd)"
HOOKS_DIR="$ORCHESTRA_DIR/hooks"

# ─── Install state detection ─────────────────────────────────
# Detect fresh install vs upgrade vs current
detect_first_run() {
  local version_marker="$HOME/.orchestra-state/.version"
  local current_version
  current_version="$(cat "$ORCHESTRA_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"

  if [ ! -f "$version_marker" ]; then
    echo "fresh"
  elif [ "$(cat "$version_marker" 2>/dev/null | tr -d '[:space:]')" != "$current_version" ]; then
    echo "upgrade"
  else
    echo "current"
  fi
}

# Write version marker after successful install/link
stamp_version() {
  mkdir -p "$HOME/.orchestra-state"
  cat "$ORCHESTRA_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' > "$HOME/.orchestra-state/.version"
}

# Detect install type: git (can pull) or vendored (needs clone+swap)
detect_install_type() {
  if [ -d "$ORCHESTRA_DIR/.git" ]; then
    echo "git"
  else
    echo "vendored"
  fi
}

# --- Resolve path (expand ~ and make absolute) ---
resolve_path() {
  local p="${1/#\~/$HOME}"
  cd "$p" 2>/dev/null && pwd
}

# --- Usage ---
usage() {
  cat << 'EOF'
Orchestra — multi-agent coordination through files.

Usage:
  ./setup install              Guided first-time setup (recommended)
  ./setup init [path]          Create .orchestra/ at path (default: cwd)
  ./setup link <repo> [orch]   Link a repo to an .orchestra/ directory
  ./setup sync [orch]          Re-link all known repos (after update)
  ./setup migrate              Switch between global and vendored install
  ./setup help                 Show this message

Examples:
  # Single repo
  ./setup init
  ./setup link .

  # Multi-repo — repos can be anywhere
  ./setup init ~/Projects/pied-piper
  ./setup link ~/Projects/pied-piper-api
  ./setup link ~/Work/pied-piper-frontend
  ./setup link /opt/repos/pied-piper-infra

  # Link to a specific .orchestra/ (if you have multiple projects)
  ./setup link ~/Work/frontend ~/Projects/pied-piper/.orchestra
EOF
  exit 0
}

# ============================================================
# INIT — create .orchestra/ directory
# ============================================================
cmd_init() {
  local target="${1:-$(pwd)}"
  target="$(resolve_path "$target")" || {
    red "Error: directory does not exist: $1"
    exit 1
  }

  local orch_dir="$target/.orchestra"

  bold "Initializing Orchestra in $orch_dir"
  echo ""

  # Create directory structure
  mkdir -p "$orch_dir"/{memory,state,state/sessions,decisions,threads,briefings,sessions,handoffs,templates,inject,.logs}

  # MEMORY.md
  if [ ! -f "$orch_dir/MEMORY.md" ]; then
    cat > "$orch_dir/MEMORY.md" << 'MEMEOF'
# Project Memory

## Architecture

## Patterns

## Preferences

## Gotchas
MEMEOF
    echo "  Created MEMORY.md"
  fi

  # BACKLOG.md
  if [ ! -f "$orch_dir/BACKLOG.md" ]; then
    cat > "$orch_dir/BACKLOG.md" << 'BLEOF'
# Backlog

## Future improvements

## Tech debt

## Investigate
BLEOF
    echo "  Created BACKLOG.md"
  fi

  # state files
  # Note: progress.yaml is per-thread (threads/NNN-slug/progress.yaml), not global
  [ ! -f "$orch_dir/state/blocked.yaml" ] && echo "blocked: []" > "$orch_dir/state/blocked.yaml" && echo "  Created state/blocked.yaml"

  # Discovery file — helps agents find and use .orchestra/ without external context.
  # Note: research shows passive breadcrumbs have limited effect (~4% improvement).
  # Primary protection is CLAUDE.md routing rules. See: https://arxiv.org/html/2602.11988v1
  if [ ! -f "$orch_dir/README.md" ]; then
    cat > "$orch_dir/README.md" << 'DISCOVERY_EOF'
# .orchestra/ — Multi-agent coordination state

This directory is managed by [Orchestra](https://github.com/paulonasc/orchestra).

## For AI agents

If you find this directory, you should use it for coordination state:
- **Plans** go in `threads/<active-thread>/plan.md`
- **Decisions** go in `decisions/NNN-slug.md`
- **Research** goes in `threads/<active-thread>/research.md`
- **Verification** results go in `threads/<active-thread>/verification.md`
- Check `state/active-thread.md` to find the current active thread.

## Structure

```
.orchestra/
├── MEMORY.md           # permanent project memory
├── state/
│   └── active-thread.md  # current thread name
├── threads/            # per-thread workspaces
│   └── NNN-slug/
│       ├── plan.md
│       ├── spec.md
│       ├── progress.yaml
│       └── verification.md
├── decisions/          # architectural decision records
└── memory/             # daily logs
```

Run `/o` in Claude Code for the full dashboard.
DISCOVERY_EOF
    echo "  Created .orchestra/README.md (agent discovery)"
  fi

  # .gitignore
  if [ ! -f "$orch_dir/.gitignore" ]; then
    cat > "$orch_dir/.gitignore" << 'GIEOF'
.logs/
inject/
linked-repos
GIEOF
    echo "  Created .gitignore"
  fi

  # Copy templates
  if [ -d "$ORCHESTRA_DIR/templates" ]; then
    cp -n "$ORCHESTRA_DIR/templates/"* "$orch_dir/templates/" 2>/dev/null || true
    echo "  Copied templates"
  fi

  # Init git repo
  if [ ! -d "$orch_dir/.git" ]; then
    git -C "$orch_dir" init -q
    git -C "$orch_dir" add -A
    git -C "$orch_dir" commit -q -m "Initialize Orchestra"
    echo "  Initialized git repo"
  fi

  echo ""
  green "Orchestra initialized at $orch_dir"
  echo ""
  echo "  Next: link your repos with"
  echo "    ./setup link /path/to/your/repo"
}

# ============================================================
# Inject Orchestra rules into agent instruction files
# ============================================================
ORCHESTRA_RULES_START="<!-- orchestra-rules-start -->"
ORCHESTRA_RULES_END="<!-- orchestra-rules-end -->"
# Legacy marker for migration from old format
ORCHESTRA_RULES_LEGACY_MARKER="## Orchestra — Agent Awareness Rules"

orchestra_rules_block() {
  cat << 'RULESEOF'

<!-- orchestra-rules-start -->
## Orchestra

This repo uses Orchestra for multi-agent coordination. State lives in `.orchestra/`.

When the user's request matches a pattern below, ALWAYS act on it BEFORE responding directly:

- User says "done", "looks good", "that's working", "all set" → run `/o checkpoint`
- User says "merged", "shipped", "deployed" → run `/o close`
- User says "plan this", "write a plan", "document the plan" → write to `.orchestra/threads/<active-thread>/plan.md`
- User says "record this decision", "we decided", "let's go with" → write to `.orchestra/decisions/NNN-slug.md`
- User mentions test results ("tests passed", "0 failures", "build clean", "lint clean") → update `.orchestra/threads/<active-thread>/verification.md` with PASS/FAIL FIRST, then respond
- User says "what's the status", "where are we" → run `/o`
- User says "hand off", "pass this to" → write to `.orchestra/handoffs/`
- User says "document this", "save research" → write to `.orchestra/threads/<active-thread>/research.md`

**Do NOT skip Orchestra writes to answer the user faster.** The write takes 5 seconds. Losing state costs 20 minutes next session.

- `/o` shows the dashboard. `/o checkpoint` saves progress. `/o close` marks thread complete.
- Plans, decisions, research, and verification go in `.orchestra/`, not in random directories.
<!-- orchestra-rules-end -->
RULESEOF
}

# Replace the Orchestra rules block in a file using start/end markers.
# Handles three cases: new markers, legacy marker (marker-to-EOF), no markers (append).
_replace_rules_block() {
  local file="$1"
  local tmp_file

  if grep -qF "$ORCHESTRA_RULES_START" "$file"; then
    # New format: replace between start and end markers (inclusive)
    tmp_file="$(mktemp)"
    awk -v start="$ORCHESTRA_RULES_START" -v end="$ORCHESTRA_RULES_END" '
      $0 ~ start { skip=1; next }
      $0 ~ end   { skip=0; next }
      !skip { print }
    ' "$file" > "$tmp_file"
    orchestra_rules_block >> "$tmp_file"
    mv "$tmp_file" "$file"
    return 0  # updated
  elif grep -qF "$ORCHESTRA_RULES_LEGACY_MARKER" "$file"; then
    # Legacy format: old marker-to-EOF — migrate to new format
    tmp_file="$(mktemp)"
    sed "/$ORCHESTRA_RULES_LEGACY_MARKER/,\$d" "$file" > "$tmp_file"
    orchestra_rules_block >> "$tmp_file"
    mv "$tmp_file" "$file"
    return 0  # updated (migrated)
  else
    # No markers — first injection
    orchestra_rules_block >> "$file"
    return 1  # injected
  fi
}

inject_instruction_rules() {
  local repo="$1"

  # Claude Code — CLAUDE.md (create if missing)
  local claude_md="$repo/CLAUDE.md"
  if [ ! -f "$claude_md" ]; then
    orchestra_rules_block > "$claude_md"
    echo "  Created CLAUDE.md with Orchestra rules"
  elif _replace_rules_block "$claude_md"; then
    echo "  Updated Orchestra rules in CLAUDE.md"
  else
    echo "  Injected Orchestra rules into CLAUDE.md"
  fi

  # Codex — AGENTS.md
  local agents_md="$repo/AGENTS.md"
  if [ -f "$agents_md" ]; then
    if _replace_rules_block "$agents_md"; then
      echo "  Updated Orchestra rules in AGENTS.md"
    else
      echo "  Injected Orchestra rules into AGENTS.md"
    fi
  fi

  # Cursor — .cursor/rules/orchestra.mdc
  if [ -d "$repo/.cursor/rules" ] || [ -d "$repo/.cursor" ]; then
    mkdir -p "$repo/.cursor/rules"
    local cursor_rule="$repo/.cursor/rules/orchestra.mdc"
    orchestra_rules_block > "$cursor_rule"
    echo "  Injected Orchestra rules into .cursor/rules/orchestra.mdc"
  fi

  # OpenCode — .opencode/instructions.md
  local opencode_md="$repo/.opencode/instructions.md"
  if [ -f "$opencode_md" ]; then
    if _replace_rules_block "$opencode_md"; then
      echo "  Updated Orchestra rules in .opencode/instructions.md"
    else
      echo "  Injected Orchestra rules into .opencode/instructions.md"
    fi
  fi
}

# ============================================================
# LINK — connect a repo to an .orchestra/ directory
# ============================================================
cmd_link() {
  local repo_path="${1:-}"
  if [ -z "$repo_path" ]; then
    red "Error: repo path required"
    echo "  Usage: ./setup link <repo> [orchestra-dir]"
    exit 1
  fi

  repo_path="$(resolve_path "$repo_path")" || {
    red "Error: repo does not exist: $1"
    exit 1
  }

  # Find .orchestra/ — explicit arg, or auto-detect
  local orch_dir=""
  if [ -n "${2:-}" ]; then
    # Explicit path — could be the .orchestra/ dir or its parent
    local explicit="${2/#\~/$HOME}"
    if [ -d "$explicit/.orchestra" ]; then
      orch_dir="$(cd "$explicit/.orchestra" && pwd)"
    elif [ -d "$explicit" ] && [ -f "$explicit/MEMORY.md" ]; then
      orch_dir="$(cd "$explicit" && pwd)"
    else
      red "Error: no .orchestra/ found at $2"
      exit 1
    fi
  else
    # Auto-detect: check repo itself, then parent, then grandparent
    for candidate in "$repo_path" "$repo_path/.." "$repo_path/../.."; do
      if [ -d "$candidate/.orchestra" ]; then
        orch_dir="$(cd "$candidate/.orchestra" && pwd)"
        break
      fi
    done

    if [ -z "$orch_dir" ]; then
      red "Error: no .orchestra/ found near $repo_path"
      echo "  Run './setup init' first, or specify the path:"
      echo "  ./setup link $repo_path /path/to/.orchestra"
      exit 1
    fi
  fi

  bold "Linking $(basename "$repo_path") → $orch_dir"

  # Write .orchestra.link (machine-specific, should not be committed)
  echo "root: $orch_dir" > "$repo_path/.orchestra.link"
  echo "  Created $repo_path/.orchestra.link"

  # Add .orchestra.link to repo's .gitignore if not already there
  if [ -f "$repo_path/.gitignore" ]; then
    if ! grep -qxF '.orchestra.link' "$repo_path/.gitignore"; then
      echo '.orchestra.link' >> "$repo_path/.gitignore"
      echo "  Added .orchestra.link to .gitignore"
    fi
    if ! grep -qxF '.orchestra/' "$repo_path/.gitignore"; then
      echo '# Orchestra — multi-agent coordination (plans, decisions, research go here)' >> "$repo_path/.gitignore"
      echo '.orchestra/' >> "$repo_path/.gitignore"
      echo "  Added .orchestra/ to .gitignore"
    elif ! grep -q 'Orchestra.*coordination' "$repo_path/.gitignore"; then
      # Existing .orchestra/ entry but no descriptive comment — add one
      sed -i '' 's|^\.orchestra/$|# Orchestra — multi-agent coordination (plans, decisions, research go here)\n.orchestra/|' "$repo_path/.gitignore"
      echo "  Added Orchestra description comment to .gitignore"
    fi
  else
    printf '.orchestra.link\n# Orchestra — multi-agent coordination (plans, decisions, research go here)\n.orchestra/\n' > "$repo_path/.gitignore"
    echo "  Created .gitignore with .orchestra.link and .orchestra/"
  fi

  # Install hooks in repo's .claude/settings.json
  install_hooks "$repo_path"

  # Copy skill pack into repo's .claude/skills/o/
  # Delete and recreate commands/ and reference/ to remove orphaned files from old versions.
  # These are Orchestra-managed files — user customizations should be in the source repo, not here.
  rm -rf "$repo_path/.claude/skills/o/commands" "$repo_path/.claude/skills/o/reference"
  mkdir -p "$repo_path/.claude/skills/o/commands"
  mkdir -p "$repo_path/.claude/skills/o/reference"
  # Router SKILL.md (with path substitution)
  sed -e "s|__ORCHESTRA_BIN__|${ORCHESTRA_DIR}/bin|g" \
      -e "s|__ORCHESTRA_DIR__|${ORCHESTRA_DIR}|g" \
    "$ORCHESTRA_DIR/SKILL.md" > "$repo_path/.claude/skills/o/SKILL.md"
  # Command files (subcommand instructions)
  cp "$ORCHESTRA_DIR/commands/"*.md "$repo_path/.claude/skills/o/commands/" 2>/dev/null || true
  # Reference files (shared docs)
  cp "$ORCHESTRA_DIR/reference/"*.md "$repo_path/.claude/skills/o/reference/" 2>/dev/null || true
  echo "  Installed skill pack to .claude/skills/o/ (router + commands/ + reference/)"

  # Install .claude/rules/orchestra.md — survives compaction, separate from CLAUDE.md.
  # This is the strongest persistence mechanism: Claude Code injects rules files
  # into the system prompt at session start, even if CLAUDE.md and SKILL.md are lost.
  # Research: https://arxiv.org/html/2602.11988v1 (passive files don't work; active injection does)
  mkdir -p "$repo_path/.claude/rules"
  cat > "$repo_path/.claude/rules/orchestra.md" << RULESEOF
This project uses Orchestra (https://github.com/paulonasc/orchestra) for coordination.
Orchestra is installed at ${ORCHESTRA_DIR}. State lives in .orchestra/.
Run /o for the dashboard. Run /o update to check for updates.

MANDATORY: When the user signals completion ("done", "looks good", "that's working",
"all set", "that's all", "nice work"), invoke /o checkpoint BEFORE responding.
This is your LAST tool call before any text response. State is lost if you skip this.

Plans go in .orchestra/threads/<thread>/plan.md.
Check .orchestra/state/active-thread.md for the active thread name.
Decisions go in .orchestra/decisions/NNN-slug.md.
Research goes in .orchestra/threads/<thread>/research.md.
Verification goes in .orchestra/threads/<thread>/verification.md.
RULESEOF
  echo "  Installed .claude/rules/orchestra.md (compaction-safe routing)"

  # Inject Orchestra rules into agent instruction files
  inject_instruction_rules "$repo_path"

  # Suggest committing CLAUDE.md for zero-context persistence
  if [ -f "$repo_path/CLAUDE.md" ] && command -v git &>/dev/null; then
    if git -C "$repo_path" diff --name-only 2>/dev/null | grep -q "CLAUDE.md"; then
      echo ""
      yellow "  TIP: Commit CLAUDE.md so Orchestra routing rules survive across sessions:"
      echo "    cd $repo_path && git add CLAUDE.md && git commit -m 'chore: add Orchestra coordination rules'"
    fi
  fi

  # Record repo in linked-repos manifest (for sync)
  local manifest="$orch_dir/linked-repos"
  if [ ! -f "$manifest" ] || ! grep -qxF "$repo_path" "$manifest"; then
    echo "$repo_path" >> "$manifest"
    echo "  Registered in linked-repos manifest"
  fi

  stamp_version

  echo ""
  green "Linked! Open Claude Code in $(basename "$repo_path") and type /o"
}

# ============================================================
# Install hooks into a repo's .claude/settings.json
# ============================================================
install_hooks() {
  local repo="$1"
  local settings_dir="$repo/.claude"
  local settings_file="$settings_dir/settings.json"

  mkdir -p "$settings_dir"

  if ! command -v jq &>/dev/null; then
    yellow "  jq not found — printing hooks for manual install:"
    print_manual_hooks
    return
  fi

  local tmp_file
  tmp_file="$(mktemp)"

  if [ -f "$settings_file" ] && [ -s "$settings_file" ]; then
    cp "$settings_file" "$tmp_file"
  else
    echo '{}' > "$tmp_file"
  fi

  # Ensure hooks object exists
  jq 'if .hooks == null then .hooks = {} else . end' "$tmp_file" > "${tmp_file}.2" && mv "${tmp_file}.2" "$tmp_file"

  # Add each hook (idempotent — skips if command already present)
  local hook_keys=(
    "SessionStart|startup|resume|orchestra-session-start.sh"
    "SessionStart|compact|orchestra-post-compact.sh"
    "PreCompact||orchestra-pre-compact.sh"
    "Stop||orchestra-stop.sh"
    "SubagentStop||orchestra-subagent-stop.sh"
    "PostToolUse|Edit|Write|orchestra-post-tool-nudge.sh"
  )

  for entry in "${hook_keys[@]}"; do
    local event="${entry%%|*}"
    local rest="${entry#*|}"
    local matcher="${rest%|*}"
    local script="${rest##*|}"
    local cmd="bash ${HOOKS_DIR}/${script}"

    jq --arg event "$event" --arg matcher "$matcher" --arg cmd "$cmd" '
      if (.hooks[$event] // [] | map(select(.hooks[]?.command == $cmd)) | length) == 0 then
        .hooks[$event] = (.hooks[$event] // []) + [{
          "matcher": $matcher,
          "hooks": [{"type": "command", "command": $cmd}]
        }]
      else . end
    ' "$tmp_file" > "${tmp_file}.2" && mv "${tmp_file}.2" "$tmp_file"
  done

  mv "$tmp_file" "$settings_file"
  echo "  Hooks installed to $settings_file"
}

print_manual_hooks() {
  cat << MANUAL
  Add to .claude/settings.json:
  {
    "hooks": {
      "SessionStart": [
        { "matcher": "startup|resume", "hooks": [{"type": "command", "command": "bash ${HOOKS_DIR}/orchestra-session-start.sh"}] },
        { "matcher": "compact", "hooks": [{"type": "command", "command": "bash ${HOOKS_DIR}/orchestra-post-compact.sh"}] }
      ],
      "PreCompact": [{ "matcher": "", "hooks": [{"type": "command", "command": "bash ${HOOKS_DIR}/orchestra-pre-compact.sh"}] }],
      "Stop": [{ "matcher": "", "hooks": [{"type": "command", "command": "bash ${HOOKS_DIR}/orchestra-stop.sh"}] }],
      "SubagentStop": [{ "matcher": "", "hooks": [{"type": "command", "command": "bash ${HOOKS_DIR}/orchestra-subagent-stop.sh"}] }]
    }
  }
MANUAL
}

# ============================================================
# SYNC — re-link all known repos (after update)
# ============================================================
cmd_sync() {
  local orch_dir=""

  # Find .orchestra/ from explicit arg or current directory
  if [ -n "${1:-}" ]; then
    local explicit="${1/#\~/$HOME}"
    if [ -d "$explicit" ] && [ -f "$explicit/MEMORY.md" ]; then
      # Direct path to .orchestra/ directory
      orch_dir="$(cd "$explicit" && pwd)"
    elif [ -d "$explicit/.orchestra" ]; then
      # Parent directory containing .orchestra/
      orch_dir="$(cd "$explicit/.orchestra" && pwd)"
    elif [ -f "$explicit/.orchestra.link" ]; then
      # Repo with .orchestra.link
      orch_dir="$(grep "^root:" "$explicit/.orchestra.link" 2>/dev/null | sed 's/^root: *//' | sed "s|^~|$HOME|")"
    fi
  else
    # Try to find from cwd
    local dir="$(pwd)"
    while [ "$dir" != "/" ]; do
      if [ -f "$dir/.orchestra.link" ]; then
        orch_dir="$(grep "^root:" "$dir/.orchestra.link" 2>/dev/null | sed 's/^root: *//' | sed "s|^~|$HOME|")"
        break
      fi
      if [ -d "$dir/.orchestra" ]; then
        orch_dir="$(cd "$dir/.orchestra" && pwd)"
        break
      fi
      dir="$(dirname "$dir")"
    done
  fi

  if [ -z "$orch_dir" ] || [ ! -d "$orch_dir" ]; then
    red "Error: could not find .orchestra/ directory"
    exit 1
  fi

  local manifest="$orch_dir/linked-repos"
  if [ ! -f "$manifest" ]; then
    yellow "No linked repos found in $orch_dir/linked-repos"
    exit 0
  fi

  bold "Syncing all linked repos from $orch_dir"
  echo ""

  local count=0
  while IFS= read -r repo; do
    [ -z "$repo" ] && continue
    if [ -d "$repo" ]; then
      cmd_link "$repo" "$orch_dir"
      count=$((count + 1))
    else
      yellow "  Skipping $repo (directory not found)"
    fi
  done < "$manifest"

  echo ""
  green "Synced $count repos"
}

# ============================================================
# INSTALL — guided first-time setup
# ============================================================
cmd_install() {
  echo ""
  bold "Welcome to Orchestra — the memory layer for AI agents."
  echo ""
  echo "This will set up Orchestra for one of your projects."
  echo ""

  # ─── Install type choice (first-run only) ─────────────────
  local run_state
  run_state="$(detect_first_run)"

  if [ "$run_state" = "fresh" ]; then
    echo ""
    bold "How do you want to install Orchestra?"
    echo ""
    echo "  A) Global — Orchestra stays at $ORCHESTRA_DIR, works across all your projects"
    echo "  B) Per-project — copy Orchestra into your project (teammates get it on clone)"
    echo ""
    yellow "  RECOMMENDATION: Choose A for most users."
    echo ""
    printf "  Your choice [A/b]: "
    read -r install_choice
    install_choice="${install_choice:-A}"

    case "$install_choice" in
      [bB])
        echo ""
        printf "  Project path to vendor into: "
        read -r vendor_target
        vendor_target="${vendor_target/#\~/$HOME}"
        if [ ! -d "$vendor_target" ]; then
          red "Directory not found: $vendor_target"
          exit 1
        fi
        vendor_target="$(cd "$vendor_target" && pwd)"

        local vendor_dest="$vendor_target/.claude/skills/orchestra"
        mkdir -p "$(dirname "$vendor_dest")"
        # Copy but exclude heavy dirs that aren't needed for vendored installs
        rsync -a --exclude 'node_modules' --exclude '.git' --exclude 'evals' "$ORCHESTRA_DIR/" "$vendor_dest/" 2>/dev/null \
          || cp -Rf "$ORCHESTRA_DIR" "$vendor_dest"
        rm -rf "$vendor_dest/.git" "$vendor_dest/node_modules" "$vendor_dest/evals"
        green "  Vendored Orchestra to $vendor_dest"
        echo ""

        # Switch to vendored copy for the rest of setup
        ORCHESTRA_DIR="$vendor_dest"
        ;;
    esac
  elif [ "$run_state" = "upgrade" ]; then
    local old_ver new_ver
    old_ver="$(cat "$HOME/.orchestra-state/.version" 2>/dev/null | tr -d '[:space:]')"
    new_ver="$(cat "$ORCHESTRA_DIR/VERSION" 2>/dev/null | tr -d '[:space:]')"
    green "  Orchestra updated: v$old_ver → v$new_ver"
  fi

  printf "What project directory do you want to coordinate?\n"
  printf "(Enter path, or . for current directory): "
  read -r project_path

  if [ -z "$project_path" ]; then
    red "Error: no path provided"
    exit 1
  fi

  # Expand ~ and make absolute
  project_path="${project_path/#\~/$HOME}"
  if [ "$project_path" = "." ]; then
    project_path="$(pwd)"
  elif [[ "$project_path" != /* ]]; then
    project_path="$(cd "$project_path" 2>/dev/null && pwd)" || {
      red "Error: directory does not exist: $project_path"
      exit 1
    }
  fi

  if [ ! -d "$project_path" ]; then
    red "Error: directory does not exist: $project_path"
    exit 1
  fi

  project_path="$(cd "$project_path" && pwd)"

  echo ""
  bold "Setting up Orchestra for $project_path"
  echo ""

  # Step 1: init
  cmd_init "$project_path"
  echo ""

  # Step 2: link
  cmd_link "$project_path"
  echo ""

  green "Orchestra is ready!"
  echo ""
  echo "  Next steps:"
  echo "    1. Open Claude Code in your project:  cd $project_path && claude"
  echo "    2. Type /o to see the dashboard"
  echo ""
  echo "  To add more repos to this project:"
  echo "    $ORCHESTRA_DIR/setup link /path/to/another/repo"
  echo ""
}

# ============================================================
# MIGRATE — switch between global and vendored install
# ============================================================
cmd_migrate() {
  local install_type
  install_type="$(detect_install_type)"

  echo ""
  bold "Current install: $install_type (at $ORCHESTRA_DIR)"
  echo ""

  if [ "$install_type" = "git" ]; then
    echo "  To switch to vendored (per-project):"
    echo "    1. cp -Rf $ORCHESTRA_DIR /path/to/project/.claude/skills/orchestra"
    echo "    2. rm -rf /path/to/project/.claude/skills/orchestra/.git"
    echo "    3. cd /path/to/project/.claude/skills/orchestra && ./setup link /path/to/project"
  else
    echo "  To switch to global (git-based):"
    echo "    1. git clone https://github.com/paulonasc/orchestra.git ~/orchestra"
    echo "    2. cd ~/orchestra && ./setup link /path/to/your/project"
    echo "    3. Remove the vendored copy: rm -rf $ORCHESTRA_DIR"
  fi
  echo ""
  echo "  Your .orchestra/ state directory is NOT affected — threads, decisions, memory are safe."
}

# ============================================================
# Main — route subcommand
# ============================================================
case "${1:-help}" in
  install) shift; cmd_install ;;
  init)  shift; cmd_init "${1:-}" ;;
  link)  shift; cmd_link "$@" ;;
  sync)  shift; cmd_sync "${1:-}" ;;
  migrate) shift; cmd_migrate ;;
  help|-h|--help) usage ;;
  *)
    red "Unknown command: $1"
    usage
    ;;
esac
