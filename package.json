{
  "name": "orchestra",
  "version": "0.4.1",
  "private": true,
  "scripts": {
    "test": "bun test",
    "test:hooks": "bun test evals/hooks/",
    "test:evals": "ls evals/cases/*.test.ts | xargs -P5 -I{} sh -c 'EVALS=1 bun test \"$1\" --retry 2 2>&1' _ {}",
    "eval": "ls evals/cases/*.test.ts | xargs -P5 -I{} sh -c 'EVALS=1 bun test \"$1\" --retry 2 2>&1' _ {}",
    "lint": "eslint evals/ --ext .ts",
    "gen:skill": "bun scripts/gen-skill.ts",
    "gen:skill:check": "bun scripts/gen-skill.ts --dry-run"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/bun": "^1.3.11",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "openai": "^5.0.0"
  }
}
